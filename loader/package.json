{
  "name": "vexion-all-in-one-loader",
  "version": "1.1.2",
  "description": "Premium All-In-One Cheat Loader",
  "main": "main.js",
  "author": "VEXION-Development",
  "scripts": {
    "start": "electron .",
    "start-panel": "electron panel-main.js",
    "build": "electron-builder",
    "build-panel": "electron-builder --config electron-builder-panel.json",
    "publish": "electron-builder --publish always"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffyNoJumper/My_Auth_API"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "discord-rpc": "^4.0.1",
    "dotenv": "^17.2.4",
    "electron-updater": "^6.1.7",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "node-addon-api": "^7.1.0"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.vex.allinone",
    "productName": "VEXION ALL-IN-ONE",
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "bin/**"
    ],
    "copyright": "Copyright © 2026 VEXION-Development",
    "directories": {
      "output": "VEX ALL IN-ONE LOADER"
    },
    "files": [
      "**/*",
      "!assets/*",
      "!Volumeid64.exe",
      "!Volumeid.exe",
      "!Eula.txt",
      "!Backend/Kernel/*",
      "build/Release/spoofer.node"
    ],
    "win": {
      "target": "nsis",
      "icon": "VEXION.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  }
}
